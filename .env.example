# Backends: "fake" (default, no keys) or "stripe" / "telegram"
BOT_PAYMENT_BACKEND=fake
BOT_CHAT_BACKEND=fake

# Stripe (required when BOT_PAYMENT_BACKEND=stripe)
BOT_STRIPE_SECRET_KEY=sk_test_xxx
BOT_STRIPE_WEBHOOK_SECRET=whsec_xxx

# Telegram (required when BOT_CHAT_BACKEND=telegram)
BOT_TELEGRAM_BOT_TOKEN=123456:ABC
BOT_TELEGRAM_CHAT_ID=-1001234567890

BOT_PUBLIC_URL=http://localhost:8000
